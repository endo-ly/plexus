#!/usr/bin/env bash
# muxport-gateway systemd サービス管理
#
# 使い方:
#   ./plexus install [WORKDIR]   # systemd に登録して起動
#   ./plexus uninstall           # 停止して登録解除
#   ./plexus status              # サービス状態を表示
#   ./plexus update              # git pull + 再起動 + ヘルスチェック
#   ./plexus restart             # 再起動 + ヘルスチェック
#   ./plexus logs [-f] [-n N]    # ログを表示

set -euo pipefail

# sudo の secure_path で ~/.local/bin が消えるのを防ぐ
export PATH="$HOME/.local/bin:$PATH"

SERVICE_NAME="plexus-gateway"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKDIR_DEFAULT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
TEMPLATE="${SCRIPT_DIR}/${SERVICE_NAME}.service.tmpl"

HEALTH_PORT_DEFAULT=8001
HEALTH_TIMEOUT=5

# ── ユーティリティ ──────────────────────────────────────────────

info()  { printf "\033[1;34m[INFO]\033[0m  %s\n" "$*"; }
ok()    { printf "\033[1;32m[OK]\033[0m    %s\n" "$*"; }
warn()  { printf "\033[1;33m[WARN]\033[0m  %s\n" "$*"; }
error() { printf "\033[1;31m[ERROR]\033[0m %s\n" "$*" >&2; exit 1; }

check_root() {
  if [[ $EUID -ne 0 ]]; then
    error "この操作には root 権限が必要です。sudo で実行してください。"
  fi
}

check_installed() {
  if [[ ! -f "$SERVICE_FILE" ]]; then
    error "サービスがインストールされていません。先に install を実行してください。"
  fi
}

find_uv() {
  local uv_path
  uv_path="$(command -v uv 2>/dev/null || true)"
  if [[ -z "$uv_path" ]]; then
    error "uv が見つかりません。https://docs.astral.sh/uv/ からインストールしてください。"
  fi
  printf "%s" "$uv_path"
}

detect_health_port() {
  local env_file="${WORKDIR_DEFAULT}/gateway/.env"
  local port="${HEALTH_PORT_DEFAULT}"

  if [[ -f "$env_file" ]]; then
    local env_port
    env_port="$(grep -oP '^GATEWAY_PORT=\K\d+' "$env_file" 2>/dev/null || true)"
    if [[ -n "$env_port" ]]; then
      port="$env_port"
    fi
  fi

  printf "%s" "$port"
}

wait_for_healthy() {
  local port
  port="$(detect_health_port)"
  local url="http://127.0.0.1:${port}/health"
  local retries=10
  local i

  info "ヘルスチェック: ${url}"

  for ((i = 1; i <= retries; i++)); do
    if curl -sf --max-time "${HEALTH_TIMEOUT}" "$url" > /dev/null 2>&1; then
      ok "ヘルスチェック OK (${i}回目)"
      return 0
    fi
    sleep 1
  done

  warn "ヘルスチェックが ${retries}回の試行で通りませんでした"
  info "ログを確認してください: sudo ${SCRIPT_DIR}/plexus logs -n 30"
  return 1
}

# ── テンプレート描画 ────────────────────────────────────────────

render_template() {
  local workdir="$1"
  local uv_path="$2"
  local user="${SUDO_USER:-$(whoami)}"
  local group

  group="$(id -gn "$user" 2>/dev/null || printf "%s" "$user")"

  sed \
    -e "s|__WORKDIR__|${workdir}|g" \
    -e "s|__UV__|${uv_path}|g" \
    -e "s|__USER__|${user}|g" \
    -e "s|__GROUP__|${group}|g" \
    "$TEMPLATE"
}

# ── サブコマンド ─────────────────────────────────────────────────

do_install() {
  local workdir="${1:-${WORKDIR_DEFAULT}}"
  local uv_path

  check_root

  # バリデーション
  if [[ ! -d "$workdir" ]]; then
    error "${workdir} が見つかりません。WORKDIR を確認してください。"
  fi
  if [[ ! -f "$workdir/gateway/main.py" ]]; then
    error "${workdir}/gateway/main.py が見つかりません。"
  fi
  if [[ ! -f "$TEMPLATE" ]]; then
    error "テンプレートファイルが見つかりません: ${TEMPLATE}"
  fi

  uv_path="$(find_uv)"

  info "Muxport Gateway を systemd にインストールします"
  info "  WorkDir: ${workdir}"
  info "  uv:      ${uv_path}"
  info "  User:    ${SUDO_USER:-$(whoami)}"
  echo ""

  # 既存サービスの停止（冪等）
  if systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then
    info "既存サービスを停止します..."
    systemctl stop "$SERVICE_NAME"
  fi

  # テンプレート描画 & 配置
  render_template "$workdir" "$uv_path" > "$SERVICE_FILE"
  ok "サービスファイルを配置: ${SERVICE_FILE}"

  # systemd 再読込 & 有効化
  systemctl daemon-reload
  systemctl enable "$SERVICE_NAME"
  ok "自動起動を有効化しました"

  # 起動
  systemctl start "$SERVICE_NAME"
  sleep 1

  # 起動確認
  if systemctl is-active --quiet "$SERVICE_NAME"; then
    ok "サービスが起動しました"
  else
    warn "サービスが起動していない可能性があります。ログを確認してください:"
    echo "  journalctl -u ${SERVICE_NAME} -n 20 --no-pager"
  fi

  echo ""
  info "コマンド一覧:"
  echo "  sudo ${SCRIPT_DIR}/plexus update       # 更新"
  echo "  sudo ${SCRIPT_DIR}/plexus restart      # 再起動"
  echo "  ${SCRIPT_DIR}/plexus logs -f           # ログ追跡"
  echo "  sudo ${SCRIPT_DIR}/plexus uninstall    # アンインストール"
}

do_uninstall() {
  check_root

  info "Muxport Gateway をアンインストールします"

  if [[ -f "$SERVICE_FILE" ]]; then
    systemctl disable --now "$SERVICE_NAME" 2>/dev/null || true
    ok "自動起動を無効化しました"
    rm -f "$SERVICE_FILE"
    ok "サービスファイルを削除しました: ${SERVICE_FILE}"
  else
    info "サービスファイルは存在しません"
  fi

  systemctl daemon-reload
  systemctl reset-failed "$SERVICE_NAME" 2>/dev/null || true
  ok "systemd を再読込しました"

  ok "アンインストール完了"
}

do_status() {
  echo "Service: ${SERVICE_NAME}"
  echo "Unit:    ${SERVICE_FILE}"
  echo ""

  if [[ ! -f "$SERVICE_FILE" ]]; then
    warn "サービスファイルが存在しません（インストール未実行）"
    exit 0
  fi

  systemctl status "$SERVICE_NAME" --no-pager 2>/dev/null || true
}

do_update() {
  check_root
  check_installed

  local workdir="${WORKDIR_DEFAULT}"

  info "Muxport Gateway を更新します"

  cd "$workdir"

  local before after

  before="$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")"

  info "git pull --ff-only を実行中..."
  if ! git pull --ff-only 2>&1; then
    error "git pull に失敗しました。ローカルの変更がある可能性があります。"
  fi

  after="$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")"

  if [[ "$before" == "$after" ]]; then
    ok "既に最新です (${after})"
  else
    ok "更新完了: ${before} -> ${after}"
  fi

  systemctl restart "$SERVICE_NAME"
  ok "サービスを再起動しました"

  wait_for_healthy
}

do_restart() {
  check_root
  check_installed

  info "Muxport Gateway を再起動します"

  systemctl restart "$SERVICE_NAME"
  ok "サービスを再起動しました"

  wait_for_healthy
}

do_logs() {
  check_installed

  local follow=false
  local lines=50
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--follow)
        follow=true
        shift
        ;;
      -n)
        lines="${2:-50}"
        shift 2
        ;;
      -n*)
        lines="${1#-n}"
        shift
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  if $follow; then
    journalctl -u "$SERVICE_NAME" -f "${args[@]}"
  else
    journalctl -u "$SERVICE_NAME" -n "$lines" --no-pager "${args[@]}"
  fi
}

# ── メイン ───────────────────────────────────────────────────────

usage() {
  echo "使い方: $0 <command> [options]"
  echo ""
  echo "Commands:"
  echo "  install [WORKDIR]   systemd サービスを登録して起動する"
  echo "                      WORKDIR 省略時はスクリプトの親ディレクトリ"
  echo "  uninstall           サービスを停止・削除する"
  echo "  status              サービス状態を表示する"
  echo "  update              git pull + 再起動 + ヘルスチェック"
  echo "  restart             再起動 + ヘルスチェック"
  echo "  logs [-f] [-n N]    ログを表示する（デフォルト: 最新50行）"
  echo ""
  echo "例:"
  echo "  sudo ./plexus install"
  echo "  sudo ./plexus update"
  echo "  ./plexus logs -f"
  echo "  ./plexus logs -n 100"
}

cmd="${1:-}"
case "$cmd" in
  install)
    do_install "${2:-}"
    ;;
  uninstall)
    do_uninstall
    ;;
  status)
    do_status
    ;;
  update)
    do_update
    ;;
  restart)
    do_restart
    ;;
  logs)
    shift
    do_logs "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
